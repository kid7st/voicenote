{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "VoiceNote",
  "version": "0.1.2",
  "identifier": "com.kid7st.voicenote.desktop",
  "build": {
    "beforeDevCommand": "bun run build:sidecar && bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build:sidecar:universal && bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "VoiceNote",
        "width": 960,
        "height": 680,
        "minWidth": 800,
        "minHeight": 560,
        "resizable": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "app",
    "externalBin": [
      "binaries/vn",
      "binaries/bun",
      "binaries/ffprobe"
    ],
    "resources": [
      "resources/pi/**/*"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "entitlements": "entitlements.plist"
    }
  }
}
