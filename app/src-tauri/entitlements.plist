<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- Bundled bun (and the bun-compiled vn) JIT-compile at runtime. Under the
       hardened runtime these entitlements are required or the process crashes. -->
  <key>com.apple.security.cs.allow-jit</key>
  <true/>
  <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
  <true/>
  <!-- pi's node_modules may load native .node addons signed by another identity;
       and our sidecars (vn/bun/ffprobe) aren't signed by the app's team. -->
  <key>com.apple.security.cs.disable-library-validation</key>
  <true/>
</dict>
</plist>
