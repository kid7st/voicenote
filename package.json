{
  "name": "@kid7st/voicenote",
  "version": "0.17.3",
  "description": "Voice recordings → diarized transcripts → integrated semantic Markdown notes. Currently optimized for the PHILIPS VTR6500 recorder, but the workflow is generic.",
  "type": "module",
  "license": "MIT",
  "author": "kid7st",
  "homepage": "https://github.com/kid7st/voicenote",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kid7st/voicenote.git"
  },
  "bugs": {
    "url": "https://github.com/kid7st/voicenote/issues"
  },
  "keywords": [
    "voice",
    "voicenote",
    "transcription",
    "diarization",
    "meeting-notes",
    "philips",
    "cli",
    "bun"
  ],
  "bin": {
    "vn": "dist/cli.mjs"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "bun src/cli.ts",
    "typecheck": "tsc --noEmit",
    "doctor": "bun src/cli.ts doctor",
    "prepublishOnly": "bun run typecheck && bun run build"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  },
  "dependencies": {
    "@earendil-works/pi-ai": "^0.79.3",
    "cac": "latest"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "tsdown": "latest",
    "typescript": "latest",
    "unrun": "^0.3.0"
  },
  "engines": {
    "bun": ">=1.3.0"
  }
}
